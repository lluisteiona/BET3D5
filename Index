function initFirebase() {
  const el = document.getElementById('fbStatus');
  if (!window._firebaseReady) { el.textContent = '● Local'; return; }
  el.textContent = '● Firebase'; el.classList.add('ok');

  const { collection, onSnapshot } = window._fs;
  onSnapshot(collection(window._db, 'diades'), snap => {
    diades = snap.docs.map(d => ({ id:d.id, ...d.data() }));
    diades.sort((a,b) => (a.data||'').localeCompare(b.data||''));
    renderDiades();
    renderDadList();
  });
}

async function saveDiada(data) {
  if (!window._firebaseReady) {
    const id = 'local_' + Date.now();
    diades.push({ id, ...data });
    diades.sort((a,b)=>(a.data||'').localeCompare(b.data||''));
    renderDiades(); renderDadList();
    return id;
  }
  const { collection, addDoc, serverTimestamp } = window._fs;
  const ref = await addDoc(collection(window._db,'diades'), { ...data, createdAt: serverTimestamp() });
  return ref.id;
}

async function updateDiada(id, data) {
  const idx = diades.findIndex(d => d.id === id);
  if (idx >= 0) diades[idx] = { ...diades[idx], ...data };
  if (!window._firebaseReady) { renderDiades(); renderDadList(); return; }
  const { doc, updateDoc } = window._fs;
  await updateDoc(doc(window._db,'diades',id), data);
}

async function deleteDiada(id) {
  diades = diades.filter(d => d.id !== id);
  renderDiades(); renderDadList();
  if (!window._firebaseReady) return;
  const { doc, deleteDoc } = window._fs;
  await deleteDoc(doc(window._db,'diades',id));
}

