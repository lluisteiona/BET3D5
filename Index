/** Retorna la probabilitat ajustada de que la colla faci >= castle */
function calcProb(collaName, castle, nivell) {
  const probs = COLLA_PROBS[collaName];
  if (!probs) return 0.5;
  const baseProb = probs[castle];
  if (baseProb === undefined || baseProb === 0) return 0;

  // Aplica el multiplicador de nivell (1-5, neutre = 3)
  const idx = Math.max(0, Math.min(4, (nivell || 3) - 1));
  let p = baseProb * NIVELL_MULT[idx];

  // Clamp entre 1% i 97%
  return Math.max(0.01, Math.min(0.97, p));
}

/** Converteix probabilitat a quota decimal aplicant el marge */
function probToOdds(prob) {
  if (prob <= 0) return gP.quotaMax;
  // Quota justa = 1/p. Amb marge: reduïm la quota
  const fair = 1 / prob;
  const withMargin = fair * (1 - gP.marge);
  return Math.max(gP.quotaMin, Math.min(gP.quotaMax, Math.round(withMargin * 100) / 100));
}

/**
 * Genera automàticament castells representatius per una colla+nivell.
 * Busca castells no-pilar amb probabilitats ajustades en rangs interessants.
 */
function autoCastells(collaName, nivell) {
  const probs = COLLA_PROBS[collaName];
  if (!probs) return [];

  // Candidats: castells no pilar amb prob ajustada > 3% i < 96%
  const candidats = CASTELLS_ORDRE.filter(c => {
    if (PILARS.has(c)) return false;
    const p = calcProb(collaName, c, nivell);
    return p > 0.03 && p < 0.96;
  });

  if (candidats.length === 0) return [];
  if (candidats.length === 1) return [candidats[0]];
  if (candidats.length === 2) return [candidats[0], candidats[candidats.length-1]];

  // Prenem el 20è, 50è i 80è percentil del rang
  const pick = (pct) => candidats[Math.min(Math.floor(candidats.length * pct), candidats.length-1)];
  const c1 = pick(0.20);
  const c2 = pick(0.50);
  const c3 = pick(0.80);

  // Elimina duplicats (pot passar si hi ha pocs candidats)
  return [...new Set([c1,c2,c3])];
}

function autoPilar(collaName, nivell) {
  const probs = COLLA_PROBS[collaName];
  if (!probs) return null;
  const candidats = CASTELLS_ORDRE.filter(c => {
    if (!PILARS.has(c)) return false;
    const p = calcProb(collaName, c, nivell);
    return p > 0.03 && p < 0.96;
  });
  if (candidats.length === 0) return null;
  return candidats[Math.floor(candidats.length / 2)];
}

/** Retorna les opcions d'aposta (fins 3 castells + pilar) per una colla en una diada */
function getBetOptions(diada, collaName) {
  const collaConf = (diada.colles||[]).find(c => c.nom === collaName);
  if (!collaConf) return [];

  const nivell = collaConf.nivell || 3;
  const castells = collaConf.castells || [];
  const pilar = collaConf.pilar || null;

  const opts = [];
  castells.forEach((c, i) => {
    if (!c) return;
    const p = calcProb(collaName, c, nivell);
    if (p <= 0) return;
    opts.push({ type:'castell', slot:i+1, castle:c, odds:probToOdds(p), prob:p });
  });
  if (pilar) {
    const p = calcProb(collaName, pilar, nivell);
    if (p > 0) opts.push({ type:'pilar', slot:null, castle:pilar, odds:probToOdds(p), prob:p });
  }
  return opts;
}

