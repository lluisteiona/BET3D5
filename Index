// ── Editar diada
function openEdit(id) {
  const diada = diades.find(d => d.id === id);
  if (!diada) return;

  const castOpts = (collaName, excl) => CASTELLS_ORDRE
    .filter(c => !PILARS.has(c) && (COLLA_PROBS[collaName]?.[c]||0) > 0)
    .map(c => `<option value="${c}" ${excl===c?'selected':''}>${c}</option>`).join('');
  const pilarOpts = (collaName, excl) => CASTELLS_ORDRE
    .filter(c => PILARS.has(c) && (COLLA_PROBS[collaName]?.[c]||0) > 0)
    .map(c => `<option value="${c}" ${excl===c?'selected':''}>${c}</option>`).join('');

  document.getElementById('editBody').innerHTML = `
    <div class="frow2 fg">
      <div><label class="fl">Nom</label><input class="fi" id="eNom" value="${diada.nom}"></div>
      <div><label class="fl">Data</label><input class="fi" type="date" id="eData" value="${diada.data||''}"></div>
    </div>
    <div class="fg"><label class="fl">Lloc</label><input class="fi" id="eLloc" value="${diada.lloc||''}"></div>

    <div style="font-size:.85rem;color:var(--text2);margin-bottom:10px;">Configuració de colles:</div>
    <div class="colla-cfg-list">
      ${(diada.colles||[]).map(c => `
        <div class="colla-cfg-item">
          <div class="colla-cfg-top">
            <div class="colla-cfg-name">🏰 ${c.nom}</div>
            <div style="display:flex;align-items:center;gap:6px;font-size:.82rem;color:var(--text2);">
              Nivell:
              <select class="lsel" id="eniv_${c.nom}">
                ${NIVELLS_NOM.map((n,i) => `<option value="${i+1}" ${(c.nivell||3)===(i+1)?'selected':''}>${n}</option>`).join('')}
              </select>
            </div>
          </div>
          <div class="colla-cfg-row">
            <div class="colla-cfg-field"><label>Castell 1</label>
              <select id="ec1_${c.nom}"><option value="">— cap —</option>${castOpts(c.nom, c.castells?.[0])}</select></div>
            <div class="colla-cfg-field"><label>Castell 2</label>
              <select id="ec2_${c.nom}"><option value="">— cap —</option>${castOpts(c.nom, c.castells?.[1])}</select></div>
            <div class="colla-cfg-field"><label>Castell 3</label>
              <select id="ec3_${c.nom}"><option value="">— cap —</option>${castOpts(c.nom, c.castells?.[2])}</select></div>
            <div class="colla-cfg-field"><label>Pilar</label>
              <select id="epil_${c.nom}"><option value="">— cap —</option>${pilarOpts(c.nom, c.pilar)}</select></div>
          </div>
          <div style="margin-top:10px;display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--text2);">
            👥 Gent prevista:
            <input type="number" class="gent-input" id="egent_${c.nom}" value="${c.gent||''}" placeholder="Ex: 800" min="0" style="width:100px;">
          </div>
        </div>`).join('')}
    </div>
    <div style="display:flex;gap:10px;margin-top:20px;">
      <button class="btn btn-green" style="padding:10px 24px;" onclick="saveEdit('${id}')">💾 Guardar canvis</button>
      <button class="btn btn-outline" onclick="closeEdit()">Cancel·lar</button>
    </div>`;

  document.getElementById('editModal').style.display = 'block';
}

function closeEdit() { document.getElementById('editModal').style.display = 'none'; }

async function saveEdit(id) {
  const diada = diades.find(d => d.id === id);
  if (!diada) return;

  const nom = document.getElementById('eNom').value.trim() || diada.nom;
  const data = document.getElementById('eData').value || diada.data;
  const lloc = document.getElementById('eLloc').value.trim() || diada.lloc;

  const colles = (diada.colles||[]).map(c => {
    const get = id => document.getElementById(id)?.value || '';
    return {
      ...c,
      nivell: parseInt(document.getElementById('eniv_'+c.nom)?.value || c.nivell || 3),
      castells: [get('ec1_'+c.nom), get('ec2_'+c.nom), get('ec3_'+c.nom)].filter(Boolean),
      pilar: get('epil_'+c.nom) || null,
      gent: parseInt(document.getElementById('egent_'+c.nom)?.value) || null
    };
  });

  await updateDiada(id, { nom, data, lloc, colles });
  closeEdit();
  notify('✅ Diada actualitzada!');
}

async function confirmDel(id, nom) {
  if (!confirm(`Eliminar "${nom}"?`)) return;
  await deleteDiada(id);
  notify('Diada eliminada');
}

