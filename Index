<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BET3D5 — Apostes Castelleres</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;500;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getFirestore, collection, addDoc, doc, updateDoc, deleteDoc, onSnapshot, serverTimestamp }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  // =============================================
  // CONFIGURACIÓ FIREBASE — EDITA AQUÍ
  // =============================================
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    projectId: "YOUR_PROJECT_ID",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_SENDER_ID",
    appId: "YOUR_APP_ID"
  };
  // =============================================

  try {
    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    window._db = db;
    window._fs = { collection, addDoc, doc, updateDoc, deleteDoc, onSnapshot, serverTimestamp };
    window._firebaseReady = true;
  } catch(e) {
    window._firebaseReady = false;
    console.warn("Firebase no configurat, mode local:", e.message);
  }
</script>

<style>
:root {
  --bg:#0a0e17; --bg2:#0f1520; --bg3:#151d2e;
  --border:#1e2d45; --accent:#f5a623; --accent2:#e8891a;
  --green:#1db954; --red:#e63946; --blue:#2196f3;
  --text:#e8eaf0; --text2:#8a9bb5; --gold:#ffd700;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* HEADER */
header{background:var(--bg2);border-bottom:2px solid var(--accent);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100;box-shadow:0 4px 20px rgba(0,0,0,.5);}
.logo{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--accent);letter-spacing:3px;text-shadow:0 0 20px rgba(245,166,35,.4);}
.logo span{color:var(--text);}
.logo em{color:var(--green);font-style:normal;font-size:.9rem;margin-left:8px;vertical-align:middle;}
.nav-btns{display:flex;gap:10px;align-items:center;}
.fbstatus{font-size:.7rem;padding:3px 8px;border-radius:12px;background:rgba(255,0,0,.1);color:#ff6b6b;}
.fbstatus.ok{background:rgba(29,185,84,.1);color:var(--green);}

/* BUTTONS */
.btn{padding:8px 16px;border-radius:4px;border:none;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.95rem;font-weight:600;letter-spacing:.5px;transition:all .2s;}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text2);}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);}
.btn-gold{background:var(--accent);color:#000;}
.btn-gold:hover{background:var(--accent2);}
.btn-green{background:var(--green);color:#000;}
.btn-green:hover{background:#17a347;}
.btn-red{background:var(--red);color:#fff;}
.btn-red:hover{background:#c73040;}
.btn-sm{padding:5px 10px;font-size:.8rem;}

/* LAYOUT */
.container{max-width:1400px;margin:0 auto;padding:20px;}
.main-grid{display:grid;grid-template-columns:1fr 340px;gap:20px;}
@media(max-width:900px){.main-grid{grid-template-columns:1fr;}}

/* BETSLIP */
.betslip{background:var(--bg2);border:1px solid var(--border);border-radius:8px;position:sticky;top:80px;max-height:calc(100vh - 100px);overflow-y:auto;display:flex;flex-direction:column;}
.bs-header{background:var(--accent);padding:12px 16px;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#000;letter-spacing:2px;display:flex;justify-content:space-between;align-items:center;}
.bs-count{background:#000;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:.85rem;}
.bs-body{padding:12px;flex:1;}
.bs-empty{text-align:center;padding:30px 10px;color:var(--text2);font-size:.9rem;}
.bs-item{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:10px 12px;margin-bottom:8px;position:relative;}
.bs-item-title{font-weight:600;font-size:.85rem;margin-bottom:2px;}
.bs-item-sub{font-size:.75rem;color:var(--text2);}
.bs-item-odds{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:var(--accent);}
.bs-remove{position:absolute;top:8px;right:8px;background:none;border:none;color:var(--text2);cursor:pointer;font-size:1rem;}
.bs-remove:hover{color:var(--red);}
.bs-total{border-top:1px solid var(--border);padding:12px;}
.bs-row{display:flex;justify-content:space-between;margin-bottom:6px;font-size:.85rem;}
.bs-row.big{font-size:1rem;font-weight:700;}
.stake-input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:8px 12px;color:var(--text);font-family:'Barlow',sans-serif;font-size:1rem;margin:8px 0;}
.stake-input:focus{outline:none;border-color:var(--accent);}
.quick-stakes{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
.qs{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:4px 10px;border-radius:4px;cursor:pointer;font-size:.8rem;transition:all .15s;}
.qs:hover{border-color:var(--accent);color:var(--accent);}

/* SECTION */
.section-title{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:2px;color:var(--accent);margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--border);}

/* DIADA CARD */
.diada-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;margin-bottom:20px;overflow:hidden;}
.diada-hdr{background:linear-gradient(135deg,var(--bg3) 0%,#1a2540 100%);padding:16px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);}
.diada-name{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;}
.diada-date{color:var(--text2);font-size:.85rem;}
.diada-badge{background:var(--green);color:#000;padding:3px 10px;border-radius:12px;font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:700;text-transform:uppercase;}

/* COLLA TABS */
.colla-section{padding:16px 20px;}
.colla-tabs{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.ctab{padding:6px 14px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.9rem;font-weight:600;transition:all .15s;}
.ctab.active{background:var(--accent);color:#000;border-color:var(--accent);}
.ctab:hover:not(.active){border-color:var(--accent);color:var(--accent);}

/* BET TABLE */
.bet-table{width:100%;border-collapse:collapse;}
.bet-table th{background:var(--bg3);padding:8px 10px;text-align:left;font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);}
.bet-table td{padding:8px 10px;border-bottom:1px solid rgba(30,45,69,.5);}
.bet-table tr:last-child td{border-bottom:none;}
.bet-table tr:hover td{background:rgba(245,166,35,.04);}
.bet-table tr.sel td{background:rgba(245,166,35,.06);}

/* ODDS BUTTON */
.odds-btn{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:6px 14px;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;align-items:center;min-width:72px;}
.odds-btn:hover{border-color:var(--accent);background:rgba(245,166,35,.1);}
.odds-btn.sel{background:var(--accent);border-color:var(--accent);}
.odds-val{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:var(--accent);line-height:1;}
.odds-btn.sel .odds-val{color:#000;}
.odds-lbl{font-size:.65rem;color:var(--text2);text-transform:uppercase;}
.odds-btn.sel .odds-lbl{color:#000;opacity:.7;}
.type-badge{font-size:.75rem;padding:2px 7px;border-radius:3px;font-weight:600;}
.type-castell{background:rgba(245,166,35,.12);color:var(--accent);}
.type-pilar{background:rgba(33,150,243,.15);color:var(--blue);}

/* COLLA INFO BAR */
.colla-info-bar{background:var(--bg3);border-radius:6px;padding:8px 12px;margin-bottom:12px;display:flex;gap:20px;font-size:.8rem;flex-wrap:wrap;}
.colla-info-item{display:flex;align-items:center;gap:6px;color:var(--text2);}
.colla-info-item strong{color:var(--text);}

/* ADMIN MODAL */
.modal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.85);backdrop-filter:blur(4px);overflow-y:auto;}
.modal-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;max-width:960px;margin:40px auto;overflow:hidden;}
.modal-hdr{background:linear-gradient(135deg,#1a0a30,#0a1a40);border-bottom:2px solid var(--accent);padding:20px 24px;display:flex;justify-content:space-between;align-items:center;}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;color:var(--accent);}
.modal-body{padding:24px;}

/* ADMIN TABS */
.atabs{display:flex;gap:4px;margin-bottom:24px;border-bottom:1px solid var(--border);}
.atab{padding:10px 20px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.95rem;font-weight:600;color:var(--text2);border:none;background:none;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;}
.atab.active{color:var(--accent);border-bottom-color:var(--accent);}
.apanel{display:none;}
.apanel.active{display:block;}

/* FORM */
.fg{margin-bottom:16px;}
.fl{display:block;font-size:.85rem;color:var(--text2);margin-bottom:6px;font-weight:500;}
.fi,.fsel{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:8px 12px;color:var(--text);font-family:'Barlow',sans-serif;font-size:.9rem;transition:border-color .15s;}
.fi:focus,.fsel:focus{outline:none;border-color:var(--accent);}
.fsel option{background:var(--bg3);}
.frow2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.frow3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}

/* COLLA CONFIG IN ADMIN */
.colla-cfg-list{display:flex;flex-direction:column;gap:10px;margin-top:12px;}
.colla-cfg-item{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px 16px;}
.colla-cfg-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.colla-cfg-name{font-weight:700;font-size:1rem;flex:1;}
.lsel{background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:4px;padding:4px 8px;font-size:.85rem;cursor:pointer;}
.colla-cfg-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;}
.colla-cfg-field{display:flex;flex-direction:column;gap:4px;}
.colla-cfg-field label{font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:.4px;}
.colla-cfg-field select,.colla-cfg-field input[type=number]{background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:4px;padding:5px 8px;font-size:.85rem;width:100%;}
.gent-input{background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:4px;padding:5px 8px;font-size:.85rem;width:100%;}

/* COLLA CHECKBOXES */
.cc-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:4px;}
.cc-input{display:none;}
.cc-lbl{padding:6px 14px;border-radius:4px;border:1px solid var(--border);cursor:pointer;font-size:.85rem;transition:all .15s;background:var(--bg3);}
.cc-input:checked+.cc-lbl{background:rgba(245,166,35,.15);border-color:var(--accent);color:var(--accent);}

/* DIADA ADMIN LIST */
.dad-list{display:flex;flex-direction:column;gap:10px;}
.dad-item{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:12px 14px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;}
.dad-info{flex:1;}
.dad-name{font-weight:600;margin-bottom:4px;}
.dad-meta{font-size:.8rem;color:var(--text2);}
.dad-actions{display:flex;gap:6px;flex-shrink:0;}

/* PARAMS */
.params-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.param-card{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:16px;}
.param-lbl{font-size:.8rem;color:var(--text2);margin-bottom:6px;}
.param-val{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--accent);}
.pslider{width:100%;margin-top:8px;accent-color:var(--accent);}

/* NOTIF */
.notif{position:fixed;bottom:20px;right:20px;z-index:999;background:var(--green);color:#000;padding:12px 20px;border-radius:6px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;transform:translateY(120px);transition:transform .3s;max-width:320px;box-shadow:0 4px 16px rgba(0,0,0,.4);}
.notif.err{background:var(--red);color:#fff;}
.notif.show{transform:translateY(0);}

/* LOADER */
.loader{text-align:center;padding:40px;color:var(--text2);}
.spin{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 10px;}
@keyframes spin{to{transform:rotate(360deg);}}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
</style>
</head>
<body>

<div class="notif" id="notif"></div>

<!-- HEADER -->
<header>
  <div class="logo">BET<span>3</span>D<span>5</span><em>🏰 Apostes Castelleres</em></div>
  <div class="nav-btns">
    <span class="fbstatus" id="fbStatus">● Local</span>
    <button class="btn btn-outline" onclick="showMyBets()">Les meves apostes</button>
    <button class="btn btn-gold" onclick="openAdmin()">🔐 Admin</button>
  </div>
</header>

<!-- MAIN -->
<div class="container">
  <div class="main-grid">
    <div>
      <div class="section-title">🏛️ DIADES DISPONIBLES</div>
      <div id="diadesContainer"><div class="loader"><div class="spin"></div>Carregant...</div></div>
    </div>
    <div>
      <div class="betslip">
        <div class="bs-header">
          <span>🎯 APOSTES</span>
          <span class="bs-count" id="bsCount">0</span>
        </div>
        <div class="bs-body" id="bsBody">
          <div class="bs-empty">Selecciona quotes per apostar</div>
        </div>
        <div class="bs-total" id="bsTotal" style="display:none">
          <div class="bs-row"><span>Quota total</span><span id="totalOdds" style="color:var(--accent);font-weight:700;">1.00</span></div>
          <input class="stake-input" type="number" id="stakeInput" placeholder="Import (€)" min="1" value="10" oninput="updatePotential()">
          <div class="quick-stakes">
            <button class="qs" onclick="setStake(5)">5€</button>
            <button class="qs" onclick="setStake(10)">10€</button>
            <button class="qs" onclick="setStake(25)">25€</button>
            <button class="qs" onclick="setStake(50)">50€</button>
          </div>
          <div class="bs-row big"><span>Guany potencial</span><span id="potentialWin" style="color:var(--green)">0.00€</span></div>
          <button class="btn btn-green" style="width:100%;margin-top:8px;padding:12px;font-size:1rem;" onclick="placeBet()">💰 FER APOSTA</button>
          <button class="btn btn-outline" style="width:100%;margin-top:6px;font-size:.85rem;" onclick="clearBetslip()">Buidar apostes</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADMIN MODAL -->
<div class="modal-overlay" id="adminModal">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title">⚙️ TAULER D'ADMINISTRADOR</span>
      <button class="btn btn-outline" onclick="closeAdmin()">✕ Tancar</button>
    </div>
    <div class="modal-body">
      <div class="atabs">
        <button class="atab active" id="atab-crear" onclick="switchTab('crear',this)">Crear Diada</button>
        <button class="atab" id="atab-diades" onclick="switchTab('diades',this)">Gestionar Diades</button>
        <button class="atab" id="atab-params" onclick="switchTab('params',this)">Paràmetres Quotes</button>
      </div>

      <!-- CREAR DIADA -->
      <div class="apanel active" id="apanel-crear">
        <div class="frow2">
          <div class="fg"><label class="fl">Nom de la Diada</label><input class="fi" id="fNom" placeholder="Ex: Diada de Sant Fèlix 2025"></div>
          <div class="fg"><label class="fl">Data</label><input class="fi" type="date" id="fData"></div>
        </div>
        <div class="fg"><label class="fl">Lloc</label><input class="fi" id="fLloc" placeholder="Ex: Vilafranca del Penedès"></div>

        <div class="fg">
          <label class="fl">Colles participants <span style="color:var(--text2);font-weight:400;">(selecciona les que hi participen)</span></label>
          <div class="cc-grid" id="ccGrid"></div>
        </div>

        <div id="collesConfig"></div>

        <button class="btn btn-green" style="padding:12px 32px;margin-top:8px;" onclick="crearDiada()">✅ Crear Diada</button>
      </div>

      <!-- GESTIONAR DIADES -->
      <div class="apanel" id="apanel-diades">
        <div id="dadList"><div class="loader"><div class="spin"></div></div></div>
      </div>

      <!-- PARÀMETRES -->
      <div class="apanel" id="apanel-params">
        <p style="color:var(--text2);margin-bottom:20px;font-size:.9rem;">Paràmetres globals que afecten el càlcul de totes les quotes.</p>
        <div class="params-grid">
          <div class="param-card">
            <div class="param-lbl">Marge de la casa (%)</div>
            <div class="param-val" id="pMargeVal">8%</div>
            <input type="range" class="pslider" min="2" max="20" value="8"
              oninput="gP.marge=this.value/100;document.getElementById('pMargeVal').textContent=this.value+'%';saveParams();">
          </div>
          <div class="param-card">
            <div class="param-lbl">Factor ajust nivell (±%)</div>
            <div class="param-val" id="pNivellVal">20%</div>
            <input type="range" class="pslider" min="5" max="50" value="20"
              oninput="gP.nivellFactor=this.value/100;document.getElementById('pNivellVal').textContent=this.value+'%';saveParams();">
          </div>
          <div class="param-card">
            <div class="param-lbl">Quotes mínimes</div>
            <div class="param-val" id="pQMinVal">1.05</div>
            <input type="range" class="pslider" min="101" max="130" value="105"
              oninput="gP.quotaMin=this.value/100;document.getElementById('pQMinVal').textContent=(this.value/100).toFixed(2);saveParams();">
          </div>
          <div class="param-card">
            <div class="param-lbl">Quotes màximes</div>
            <div class="param-val" id="pQMaxVal">50.00</div>
            <input type="range" class="pslider" min="1000" max="10000" value="5000"
              oninput="gP.quotaMax=this.value/100;document.getElementById('pQMaxVal').textContent=(this.value/100).toFixed(2);saveParams();">
          </div>
        </div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:14px;margin-top:16px;font-size:.82rem;color:var(--text2);line-height:1.6;">
          💡 <strong style="color:var(--text);">Com funcionen les quotes:</strong> Cada colla té probabilitats baseades en l'historial (Excel).
          El <em>nivell per diada</em> (1-5) ajusta aquestes probabilitats ±Factor. La <em>gent prevista per colla</em>
          és informativa però no afecta el càlcul (la pressió és interna). El <em>marge de la casa</em> redueix
          les quotes netes per assegurar el benefici de la casa.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- EDIT DIADA MODAL -->
<div class="modal-overlay" id="editModal">
  <div class="modal-box" style="max-width:700px;">
    <div class="modal-hdr">
      <span class="modal-title">✏️ EDITAR DIADA</span>
      <button class="btn btn-outline" onclick="closeEdit()">✕</button>
    </div>
    <div class="modal-body" id="editBody"></div>
  </div>
</div>

<!-- MY BETS MODAL -->
<div class="modal-overlay" id="myBetsModal">
  <div class="modal-box" style="max-width:700px;">
    <div class="modal-hdr">
      <span class="modal-title">📋 LES MEVES APOSTES</span>
      <button class="btn btn-outline" onclick="document.getElementById('myBetsModal').style.display='none'">✕</button>
    </div>
    <div class="modal-body" id="myBetsBody"></div>
  </div>
</div>

<script>
// ─────────────────────────────────────────────
// DADES EXCEL — PROBABILITATS PER COLLA I CASTELL
// Font: full "NIVELL COLLA" de l'Excel
// Representa P(colla aconsegueix >= aquest castell)
// ─────────────────────────────────────────────

