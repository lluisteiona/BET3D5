        <div class="colla-tabs">${tabs}</div>
        ${infoBar}
        <table class="bet-table">
          <thead><tr><th>Tipus</th><th>Aposta</th><th>Prob. base</th><th>Quota</th></tr></thead>
          <tbody>${rows}${emptyRow}</tbody>
