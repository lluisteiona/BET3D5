// ─────────────────────────────────────────────
// BETSLIP
// ─────────────────────────────────────────────
function toggleBet(diadaId, collaName, betType, castle, odds, diadaNom) {
  const idx = bets.findIndex(b => b.diadaId===diadaId && b.collaName===collaName && b.castle===castle);
  if (idx >= 0) bets.splice(idx, 1);
  else bets.push({ diadaId, collaName, betType, castle, odds, diadaNom });
  renderBetslip();
  renderDiades();
}

function renderBetslip() {
  document.getElementById('bsCount').textContent = bets.length;
  const body = document.getElementById('bsBody');
  const total = document.getElementById('bsTotal');

  if (bets.length === 0) {
    body.innerHTML = '<div class="bs-empty">Selecciona quotes per apostar</div>';
    total.style.display = 'none';
    return;
  }

  body.innerHTML = bets.map((b,i) => `
    <div class="bs-item">
      <button class="bs-remove" onclick="removeBet(${i})">✕</button>
      <div class="bs-item-title">${b.diadaNom}</div>
      <div class="bs-item-sub">${b.collaName} — ${b.betType==='pilar'?'🔵 Pilar':'🏰 Castell'}: ${b.castle}+</div>
      <div class="bs-item-odds">${Number(b.odds).toFixed(2)}</div>
    </div>`).join('');

  total.style.display = 'block';
  updatePotential();
}

function removeBet(i) { bets.splice(i,1); renderBetslip(); renderDiades(); }
function clearBetslip() { bets=[]; renderBetslip(); renderDiades(); }

function updatePotential() {
  const totalOdds = bets.reduce((acc,b) => acc * Number(b.odds), 1);
  const stake = parseFloat(document.getElementById('stakeInput').value) || 0;
  document.getElementById('totalOdds').textContent = totalOdds.toFixed(2);
  document.getElementById('potentialWin').textContent = (stake * totalOdds).toFixed(2) + '€';
}

function setStake(v) { document.getElementById('stakeInput').value = v; updatePotential(); }

function placeBet() {
  if (bets.length === 0) return;
  const stake = parseFloat(document.getElementById('stakeInput').value);
  if (!stake || stake <= 0) { notify('Introdueix un import vàlid','err'); return; }
  const totalOdds = bets.reduce((acc,b) => acc * Number(b.odds), 1);
  myBets.unshift({
    id: Date.now(), items:[...bets], stake,
    totalOdds: totalOdds.toFixed(2),
    potential: (stake*totalOdds).toFixed(2),
    date: new Date().toLocaleString('ca-ES'), status:'pendent'
  });
  localStorage.setItem('myBets', JSON.stringify(myBets));
  clearBetslip();
  notify(`✅ Aposta de ${stake}€ realitzada! Quota: ${totalOdds.toFixed(2)}`);
}

