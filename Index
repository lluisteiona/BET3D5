}

function renderCollesConfig() {
  const sel = [...document.querySelectorAll('.cc-input:checked')].map(c => c.value);
  const container = document.getElementById('collesConfig');
  if (sel.length === 0) { container.innerHTML = ''; return; }

  container.innerHTML = `
    <div style="font-size:.85rem;color:var(--text2);margin-bottom:10px;">Configura cada colla per a aquesta diada:</div>
    <div class="colla-cfg-list">
      ${sel.map(c => {
        const castOpts = CASTELLS_ORDRE.filter(x => !PILARS.has(x) && (COLLA_PROBS[c]?.[x]||0) > 0);
        const pilarOpts = CASTELLS_ORDRE.filter(x => PILARS.has(x) && (COLLA_PROBS[c]?.[x]||0) > 0);
        const castSel = (n) => castOpts.map(x => `<option value="${x}">${x}</option>`).join('');
        const pilarSel = pilarOpts.map(x => `<option value="${x}">${x}</option>`).join('');
        return `
          <div class="colla-cfg-item">
            <div class="colla-cfg-top">
              <div class="colla-cfg-name">🏰 ${c}</div>
              <div style="display:flex;align-items:center;gap:6px;font-size:.82rem;color:var(--text2);">
                Nivell:
                <select class="lsel" id="niv_${c}" onchange="autoFillCastells('${c}')">
                  ${NIVELLS_NOM.map((n,i) => `<option value="${i+1}" ${i===2?'selected':''}>${n}</option>`).join('')}
                </select>
              </div>
            </div>
            <div class="colla-cfg-row">
              <div class="colla-cfg-field">
                <label>Castell 1 (mínim)</label>
                <select id="c1_${c}"><option value="">— cap —</option>${castSel()}</select>
              </div>
              <div class="colla-cfg-field">
                <label>Castell 2 (mínim)</label>
                <select id="c2_${c}"><option value="">— cap —</option>${castSel()}</select>
              </div>
              <div class="colla-cfg-field">
                <label>Castell 3 (mínim)</label>
                <select id="c3_${c}"><option value="">— cap —</option>${castSel()}</select>
              </div>
              <div class="colla-cfg-field">
                <label>Pilar (mínim)</label>
                <select id="pil_${c}"><option value="">— cap —</option>${pilarSel}</select>
              </div>
            </div>
            <div style="margin-top:10px;display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--text2);">
              👥 Gent prevista:
              <input type="number" class="gent-input" id="gent_${c}" placeholder="Ex: 800" min="0" max="10000" style="width:100px;">
              <span style="font-size:.75rem;color:var(--text2);">(informatiu, no afecta quotes)</span>
            </div>
          </div>`;
      }).join('')}
    </div>`;

  // Auto-omple castells per defecte amb els valors calculats
  sel.forEach(c => autoFillCastells(c));
}

function autoFillCastells(collaName) {
  const nivell = parseInt(document.getElementById('niv_' + collaName)?.value || 3);
  const castells = autoCastells(collaName, nivell);
  const pilar = autoPilar(collaName, nivell);

  const setVal = (id, val) => {
    const el = document.getElementById(id);
    if (!el || !val) return;
    // Intenta seleccionar l'opció
    for (let opt of el.options) { if (opt.value === val) { el.value = val; return; } }
  };

  setVal('c1_' + collaName, castells[0] || '');
  setVal('c2_' + collaName, castells[1] || '');
  setVal('c3_' + collaName, castells[2] || '');
  setVal('pil_' + collaName, pilar || '');
}

async function crearDiada() {
  const nom = document.getElementById('fNom').value.trim();
  const data = document.getElementById('fData').value;
  const lloc = document.getElementById('fLloc').value.trim();

  if (!nom) { notify('Introdueix un nom per la diada','err'); return; }

  const sel = [...document.querySelectorAll('.cc-input:checked')].map(c => c.value);
  if (sel.length === 0) { notify('Selecciona almenys una colla','err'); return; }

  const colles = sel.map(c => {
    const nivell = parseInt(document.getElementById('niv_' + c)?.value || 3);
    const get = id => document.getElementById(id)?.value || '';
    return {
      nom: c,
      nivell,
      castells: [get('c1_'+c), get('c2_'+c), get('c3_'+c)].filter(Boolean),
      pilar: get('pil_'+c) || null,
      gent: parseInt(document.getElementById('gent_'+c)?.value) || null
    };
  });

  const btn = event.target;
  btn.disabled = true; btn.textContent = 'Creant...';

  try {
    await saveDiada({ nom, data, lloc, colles, activa:true });
    // Reset form
    document.getElementById('fNom').value = '';
    document.getElementById('fData').value = '';
    document.getElementById('fLloc').value = '';
    document.querySelectorAll('.cc-input').forEach(c => c.checked = false);
    document.getElementById('collesConfig').innerHTML = '';
    notify('✅ Diada creada correctament!');
  } catch(e) {
    notify('Error creant la diada: ' + e.message, 'err');
  } finally {
    btn.disabled = false; btn.textContent = '✅ Crear Diada';
  }
}

